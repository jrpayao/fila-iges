# Copie para .env.local e preencha. .env.local NUNCA vai pro git.

# --- LLM (modo POC: OpenAI) ---
OPENAI_API_KEY=sk-proj-COLE_AQUI_A_CHAVE_NOVA_DEPOIS_DE_ROTACIONAR
OPENAI_PLANNER_MODEL=gpt-4o
OPENAI_NARRATOR_MODEL=gpt-4o-mini

# --- Após 2026-07-19, migração para Claude (P8 default) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_PLANNER_MODEL=claude-opus-4-7
# ANTHROPIC_NARRATOR_MODEL=claude-haiku-4-5-20251001

# --- SISREG (Elasticsearch) ---
SISREG_BASE_URL=https://sisreg-es.saude.gov.br
SISREG_UF=df                        # alias-texto usado no path do indice
SISREG_MUNICIPIO=brasilia           # alias-texto, NAO codigo IBGE
SISREG_UF_CODE_IBGE=53              # para filter "term codigo_uf_regulador"
SISREG_USER=__seu_usuario_AD__
SISREG_PASS=__sua_senha__
SISREG_CENTRAIS_REGULADORAS=530010   # central reguladora DF (confirmado via doc real)
SISREG_REQUEST_TIMEOUT_SECONDS=5

# --- Fonte v3: API de vagas SISREG (IGES) — auth por header no gateway ---
IGES_VAGAS_URL=https://api.igesdf.org.br/iges/dados_vagas_sisreg
IGES_VAGAS_CLIENT_ID=__client_id_do_gateway_iges__
IGES_VAGAS_CLIENT_SECRET=__client_secret_do_gateway_iges__
IGES_VAGAS_TIMEOUT_SECONDS=60
VAGAS_CACHE_PATH=./data/vagas_cache.sqlite

# --- Modo de operação ---
APP_MODE=poc                        # poc | producao
POC_EXPIRES_AT=2026-07-19
POC_PII_BANNER="CONTÉM PII — uso interno IGES, distribuição proibida"

# --- Audit ---
AUDIT_BACKEND=sqlite                # sqlite (dev) | postgres (prod)
AUDIT_SQLITE_PATH=./audit.db
# AUDIT_POSTGRES_URL=postgresql://user:pass@host/db
AUDIT_RETENTION_DAYS_DEFAULT=90
AUDIT_RETENTION_DAYS_PII=365

# --- Observabilidade ---
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_PORT=9090

# --- Auth (futuro) ---
# OIDC_ISSUER=https://keycloak.iges.df.gov.br/realms/iges
# OIDC_CLIENT_ID=fila-eletiva
# OIDC_CLIENT_SECRET=__set_via_secret_manager__
